# PostgreSQL connection string
# Local:   postgresql://USER:PASSWORD@localhost:5432/ascend_system
# Railway/Render/Neon/Supabase: cole a connection string fornecida pelo serviço
DATABASE_URL="postgresql://postgres:password@localhost:5432/ascend_system"

# Segredo para assinar os tokens JWT (troque por um valor aleatório forte em produção)
JWT_SECRET="troque-este-segredo-por-um-valor-aleatorio-forte"

# ── URL pública do app (usada nos e-mails e links de acesso) ──
NEXT_PUBLIC_APP_URL="https://www.ascendsystem.com.br"

# ── Resend (e-mail transacional de acesso) ──
# Crie a API key em https://resend.com/api-keys e verifique o domínio remetente.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Ascend System <acesso@ascendsystem.com.br>"

# ── Cakto (webhook de pagamento) ──
# Secret do webhook (se a Cakto fornecer) para validar a assinatura.
CAKTO_WEBHOOK_SECRET=""
# Opcional: mapear plano por ID de produto da Cakto.
CAKTO_PRODUCT_MENSAL=""
CAKTO_PRODUCT_ANUAL=""
CAKTO_PRODUCT_FUNDADOR=""

# ── Links de checkout da Cakto (frontend) ──
NEXT_PUBLIC_CAKTO_CHECKOUT_MENSAL=""
NEXT_PUBLIC_CAKTO_CHECKOUT_ANUAL=""
NEXT_PUBLIC_CAKTO_CHECKOUT_FUNDADOR=""

# ── Reenvio manual de e-mail de acesso (endpoint admin protegido) ──
ADMIN_RESEND_KEY=""
