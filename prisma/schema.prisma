generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(cuid())
  name                 String
  email                String    @unique
  passwordHash         String
  avatarUrl            String?
  level                Int       @default(1)
  currentXp            Int       @default(0)
  totalXp              Int       @default(0)
  essences             Int       @default(0)
  fragments            Int       @default(0)
  currentStreak        Int       @default(0)
  bestStreak           Int       @default(0)
  lastActiveDate       DateTime?
  penaltiesEnabled     Boolean   @default(false)
  arenaWins            Int       @default(0)
  arenaLosses          Int       @default(0)
  arenaPoints          Int       @default(0)
  seasonPoints         Int       @default(0)
  onboardingCompleted  Boolean   @default(false)
  timezone             String    @default("America/Sao_Paulo")
  goals                String[]  @default([])
  availableMinutes     Int       @default(30)
  experienceLevel      String    @default("BEGINNER")
  availableEquipment   String[]  @default([])
  healthNotes          String?
  specialization       String?
  notificationsEnabled Boolean   @default(false)
  selectedClassId      String?
  lastBattleAt         DateTime?
  arenaCharges         Int       @default(5)
  arenaNextChargeAt    DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  selectedClass      Class?              @relation(fields: [selectedClassId], references: [id])
  tasks              Task[]
  attributes         Attribute?
  userMissions       UserMission[]
  inventory          Inventory[]
  userAchievements   UserAchievement[]
  activityHistory    ActivityHistory[]
  battles            Battle[]
  taskExecutions     TaskExecution[]
  actionReceipts     ActionReceipt[]
  feedback           Feedback[]
  groupMemberships   GroupMember[]
  groupContributions GroupContribution[]
  userChests         UserChest[]
  chestOpenings      ChestOpeningLog[]
  forgeLogs          ForgeLog[]

  @@map("users")
}

model Chest {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  rank        String // E | D | C | B | A | S | SPECIAL
  description String
  icon        String
  imageUrl    String?
  createdAt   DateTime @default(now())

  userChests UserChest[]
  openings   ChestOpeningLog[]

  @@map("chests")
}

model UserChest {
  id         String   @id @default(cuid())
  userId     String
  chestId    String
  quantity   Int      @default(1)
  source     String   @default("REWARD")
  acquiredAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  chest Chest @relation(fields: [chestId], references: [id])

  @@unique([userId, chestId])
  @@map("user_chests")
}

model Enemy {
  id               String   @id @default(cuid())
  key              String   @unique
  name             String
  rank             String // E | D | C | B | A | S
  type             String
  isBoss           Boolean  @default(false)
  hp               Int
  attack           Int
  defense          Int
  weakness         String?
  resistance       String?
  specialMechanic  String?
  recommendedPower Int
  drops            String?
  icon             String
  imageUrl         String?
  createdAt        DateTime @default(now())

  @@map("enemies")
}

model ChestOpeningLog {
  id          String   @id @default(cuid())
  userId      String
  chestId     String
  rewardsJson Json
  createdAt   DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  chest Chest @relation(fields: [chestId], references: [id])

  @@index([userId, createdAt])
  @@map("chest_opening_logs")
}

model Battle {
  id            String   @id @default(cuid())
  userId        String
  opponentName  String
  opponentType  String // BOT | PLAYER
  won           Boolean
  xpChange      Int      @default(0)
  essenceChange Int      @default(0)
  pointsChange  Int      @default(0)
  seasonKey     String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@map("battles")
}

model ArenaSeason {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  startsAt  DateTime
  endsAt    DateTime
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("arena_seasons")
}

model Attribute {
  id           String @id @default(cuid())
  userId       String @unique
  strength     Int    @default(0)
  intelligence Int    @default(0)
  discipline   Int    @default(0)
  focus        Int    @default(0)
  vitality     Int    @default(0)
  charisma     Int    @default(0)
  wisdom       Int    @default(0)
  creativity   Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("attributes")
}

model Task {
  id               String         @id @default(cuid())
  userId           String
  title            String
  description      String?
  category         TaskCategory
  difficulty       TaskDifficulty
  recurrence       TaskRecurrence @default(ONCE)
  dueDate          DateTime?
  xpReward         Int
  essenceReward    Int
  status           TaskStatus     @default(PENDING)
  completedAt      DateTime?
  targetValue      Float?
  targetUnit       String?
  estimatedMinutes Int?
  isTemplate       Boolean        @default(false)
  templateName     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtasks   TaskSubtask[]
  executions TaskExecution[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, recurrence, status])
  @@map("tasks")
}

model TaskSubtask {
  id        String  @id @default(cuid())
  taskId    String
  title     String
  position  Int     @default(0)
  completed Boolean @default(false)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_subtasks")
}

model TaskExecution {
  id                  String   @id @default(cuid())
  taskId              String
  userId              String
  idempotencyKey      String   @unique
  actualValue         Float?
  durationMinutes     Int?
  perceivedDifficulty Int?
  notes               String?
  xpGained            Int      @default(0)
  essenceGained       Int      @default(0)
  completedAt         DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
  @@map("task_executions")
}

model ActionReceipt {
  id        String   @id @default(cuid())
  userId    String
  action    String
  key       String
  result    Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, action, key])
  @@index([createdAt])
  @@map("action_receipts")
}

model Class {
  id          String @id @default(cuid())
  name        String @unique
  description String
  icon        String
  bonusType   String
  bonusValue  Float  @default(0)
  color       String @default("#6366f1")

  users User[]

  @@map("classes")
}

model Mission {
  id               String      @id @default(cuid())
  title            String
  description      String
  type             MissionType
  category         String?
  requirementType  String
  requirementValue Int
  xpReward         Int
  essenceReward    Int
  itemRewardId     String?
  minDayUnlock     Int         @default(0)
  createdAt        DateTime    @default(now())

  userMissions UserMission[]
  itemReward   Equipment?    @relation(fields: [itemRewardId], references: [id])

  @@map("missions")
}

model UserMission {
  id          String        @id @default(cuid())
  userId      String
  missionId   String
  progress    Int           @default(0)
  status      MissionStatus @default(ACTIVE)
  completedAt DateTime?
  claimedAt   DateTime?
  assignedAt  DateTime      @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id])

  @@unique([userId, missionId])
  @@index([userId])
  @@index([userId, status])
  @@map("user_missions")
}

model Equipment {
  id          String    @id @default(cuid())
  name        String    @unique
  description String
  type        EquipType
  rarity      Rarity
  bonusType   String?
  bonusValue  Float     @default(0)
  price       Int
  icon        String
  imageUrl    String?
  rank        String?
  setKey      String?
  isFullSet   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  inventory     Inventory[]
  missionReward Mission[]

  @@map("equipment")
}

model Inventory {
  id             String   @id @default(cuid())
  userId         String
  equipmentId    String
  isEquipped     Boolean  @default(false)
  upgradeLevel   Int      @default(0)
  durability     Int      @default(100)
  durabilityMax  Int      @default(100)
  acquiredAt     DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id])
  forgeLogs ForgeLog[]

  @@unique([userId, equipmentId])
  @@index([userId])
  @@index([userId, isEquipped])
  @@map("inventory")
}

model ForgeLog {
  id          String   @id @default(cuid())
  userId      String
  inventoryId String
  action      String   // UPGRADE | REPAIR | ENCHANT
  success     Boolean
  costEssences Int     @default(0)
  detail      String?
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@map("forge_logs")
}

model Achievement {
  id               String @id @default(cuid())
  name             String @unique
  description      String
  icon             String
  requirementType  String
  requirementValue Int

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model ActivityHistory {
  id            String   @id @default(cuid())
  userId        String
  type          String
  description   String
  xpChange      Int      @default(0)
  essenceChange Int      @default(0)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, type])
  @@map("activity_history")
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  category  String
  message   String
  rating    Int?
  status    String   @default("OPEN")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("feedback")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  inviteCode  String   @unique
  createdAt   DateTime @default(now())

  members    GroupMember[]
  challenges GroupChallenge[]

  @@map("groups")
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model GroupChallenge {
  id          String   @id @default(cuid())
  groupId     String
  title       String
  description String?
  target      Int
  reward      Int      @default(0)
  startsAt    DateTime @default(now())
  endsAt      DateTime
  createdAt   DateTime @default(now())

  group         Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  contributions GroupContribution[]

  @@map("group_challenges")
}

model GroupContribution {
  id          String   @id @default(cuid())
  challengeId String
  userId      String
  value       Int      @default(0)
  updatedAt   DateTime @updatedAt

  challenge GroupChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@map("group_contributions")
}

enum TaskCategory {
  HEALTH
  TRAINING
  STUDY
  WORK
  FINANCE
  SPIRITUALITY
  SOCIAL
  HOME
  PERSONAL_DEVELOPMENT
  CREATIVITY
}

enum TaskDifficulty {
  EASY
  MEDIUM
  HARD
  EXTREME
}

enum TaskRecurrence {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
}

enum TaskStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum MissionType {
  DAILY
  WEEKLY
  MONTHLY
  SPECIAL
}

enum MissionStatus {
  ACTIVE
  COMPLETED
  CLAIMED
}

enum EquipType {
  WEAPON
  ARMOR
  SHIELD
  RING
  BRACELET
  AMULET
  BOOTS
  BOOK
  MEDAL
  RELIC
  HELMET
  CHESTPLATE
  PANTS
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}

model PendingMember {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  planKey   String
  token     String   @unique @default(cuid())
  orderId   String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@map("pending_members")
}
