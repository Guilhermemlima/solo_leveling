generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  passwordHash    String
  avatarUrl       String?
  level           Int       @default(1)
  currentXp       Int       @default(0)
  totalXp         Int       @default(0)
  essences        Int       @default(0)
  currentStreak   Int       @default(0)
  bestStreak      Int       @default(0)
  lastActiveDate  DateTime?
  penaltiesEnabled Boolean  @default(false)
  arenaWins       Int       @default(0)
  arenaLosses     Int       @default(0)
  arenaPoints     Int       @default(0)
  selectedClassId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  selectedClass    Class?            @relation(fields: [selectedClassId], references: [id])
  tasks            Task[]
  attributes       Attribute?
  userMissions     UserMission[]
  inventory        Inventory[]
  userAchievements UserAchievement[]
  activityHistory  ActivityHistory[]
  battles          Battle[]

  @@map("users")
}

model Battle {
  id           String   @id @default(cuid())
  userId       String
  opponentName String
  opponentType String // BOT | PLAYER
  won          Boolean
  xpChange     Int      @default(0)
  essenceChange Int     @default(0)
  pointsChange Int      @default(0)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("battles")
}

model Attribute {
  id           String @id @default(cuid())
  userId       String @unique
  strength     Int    @default(0)
  intelligence Int    @default(0)
  discipline   Int    @default(0)
  focus        Int    @default(0)
  vitality     Int    @default(0)
  charisma     Int    @default(0)
  wisdom       Int    @default(0)
  creativity   Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("attributes")
}

model Task {
  id            String         @id @default(cuid())
  userId        String
  title         String
  description   String?
  category      TaskCategory
  difficulty    TaskDifficulty
  recurrence    TaskRecurrence @default(ONCE)
  dueDate       DateTime?
  xpReward      Int
  essenceReward Int
  status        TaskStatus     @default(PENDING)
  completedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model Class {
  id          String @id @default(cuid())
  name        String @unique
  description String
  icon        String
  bonusType   String
  bonusValue  Float  @default(0)
  color       String @default("#6366f1")

  users User[]

  @@map("classes")
}

model Mission {
  id               String      @id @default(cuid())
  title            String
  description      String
  type             MissionType
  requirementType  String
  requirementValue Int
  xpReward         Int
  essenceReward    Int
  itemRewardId     String?
  createdAt        DateTime    @default(now())

  userMissions UserMission[]
  itemReward   Equipment?    @relation(fields: [itemRewardId], references: [id])

  @@map("missions")
}

model UserMission {
  id          String        @id @default(cuid())
  userId      String
  missionId   String
  progress    Int           @default(0)
  status      MissionStatus @default(ACTIVE)
  completedAt DateTime?
  claimedAt   DateTime?
  assignedAt  DateTime      @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id])

  @@unique([userId, missionId])
  @@map("user_missions")
}

model Equipment {
  id          String    @id @default(cuid())
  name        String    @unique
  description String
  type        EquipType
  rarity      Rarity
  bonusType   String?
  bonusValue  Float     @default(0)
  price       Int
  icon        String
  createdAt   DateTime  @default(now())

  inventory     Inventory[]
  missionReward Mission[]

  @@map("equipment")
}

model Inventory {
  id          String   @id @default(cuid())
  userId      String
  equipmentId String
  isEquipped  Boolean  @default(false)
  acquiredAt  DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id])

  @@map("inventory")
}

model Achievement {
  id               String @id @default(cuid())
  name             String @unique
  description      String
  icon             String
  requirementType  String
  requirementValue Int

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model ActivityHistory {
  id            String   @id @default(cuid())
  userId        String
  type          String
  description   String
  xpChange      Int      @default(0)
  essenceChange Int      @default(0)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_history")
}

enum TaskCategory {
  HEALTH
  TRAINING
  STUDY
  WORK
  FINANCE
  SPIRITUALITY
  SOCIAL
  HOME
  PERSONAL_DEVELOPMENT
  CREATIVITY
}

enum TaskDifficulty {
  EASY
  MEDIUM
  HARD
  EXTREME
}

enum TaskRecurrence {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
}

enum TaskStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum MissionType {
  DAILY
  WEEKLY
  SPECIAL
}

enum MissionStatus {
  ACTIVE
  COMPLETED
  CLAIMED
}

enum EquipType {
  WEAPON
  ARMOR
  RING
  AMULET
  BOOTS
  BOOK
  MEDAL
  RELIC
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}
